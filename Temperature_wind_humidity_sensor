# =========================
# 6) Trend analysis on training data
# =========================
trend_lines = []
trend_lines.append(f"Training rows: {len(train_df)}")
trend_lines.append(f"Training files: {len(train_file_names)}")
trend_lines.append(f"Rain rows: {int(train_df['rain_flag'].sum())}")
trend_lines.append(f"Rain frequency (%): {train_df['rain_flag'].mean() * 100:.4f}")

for col, label in [("temperature", "temperature"), ("humidity", "humidity")]:
    if train_df[col].notna().sum() > 0:
        trend_lines.append(f"Average {label} overall: {train_df[col].mean():.2f}")
    rain_vals = train_df.loc[train_df["rain_flag"] == 1, col].dropna()
    if len(rain_vals) > 0:
        trend_lines.append(f"Average {label} when raining: {rain_vals.mean():.2f}")

corr_temp_rain     = train_df[["temperature", "rain_amount"]].corr(numeric_only=True).iloc[0, 1]
corr_humidity_rain = train_df[["humidity",    "rain_amount"]].corr(numeric_only=True).iloc[0, 1]
trend_lines.append(f"Correlation: temperature vs rain_amount = {corr_temp_rain:.4f}")
trend_lines.append(f"Correlation: humidity vs rain_amount = {corr_humidity_rain:.4f}")

hourly_rain = train_df.groupby("hour_sin", dropna=True)["rain_flag"].mean().reset_index()
if len(hourly_rain) > 0:
    best_hour = hourly_rain.sort_values("rain_flag", ascending=False).iloc[0]
    trend_lines.append(f"Highest rain likelihood by hour_sin bucket: {best_hour['hour_sin']:.3f} "
                       f"({best_hour['rain_flag'] * 100:.2f}%)")

