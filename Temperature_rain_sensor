    {
      "cell_type": "code",
      "source": [
        "# ML pipeline for 6 training CSVs + 1 input CSV\n",
        "# - Upload 6 historical CSVs to train\n",
        "# - Upload 1 new CSV to analyze\n",
        "# - Extract temp/rain trends\n",
        "# - Predict rain occurrence and rain amount\n",
        "# - Save report, predictions, plots, and trained models\n",
        "\n",
        "# =========================\n",
        "# 1) Install / Imports\n",
        "# =========================\n",
        "!pip -q install joblib\n",
        "\n",
        "import io\n",
        "import os\n",
        "import re\n",
        "import json\n",
        "import math\n",
        "import joblib\n",
        "import warnings\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "from google.colab import files\n",
        "from IPython.display import display\n",
        "\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.compose import ColumnTransformer\n",
        "from sklearn.pipeline import Pipeline\n",
        "from sklearn.impute import SimpleImputer\n",
        "from sklearn.metrics import (\n",
        "    accuracy_score,\n",
        "    precision_score,\n",
        "    recall_score,\n",
        "    f1_score,\n",
        "    roc_auc_score,\n",
        "    mean_absolute_error,\n",
        "    r2_score,\n",
        ")\n",
        "from sklearn.preprocessing import OneHotEncoder, StandardScaler\n",
        "from sklearn.ensemble import RandomForestClassifier, RandomForestRegressor\n",
        "\n",
        "warnings.filterwarnings(\"ignore\")\n",
        "\n",
        "OUTPUT_DIR = \"weather_results\"\n",
        "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 2) Upload training files\n",
        "# =========================\n",
        "print(\"Upload your 6 historical/training CSV files\")\n",
        "uploaded_train = files.upload()\n",
        "\n",
        "train_file_names = list(uploaded_train.keys())\n",
        "if len(train_file_names) < 1:\n",
        "    raise ValueError(\"Please upload at least 1 training CSV.\")\n",
        "\n",
        "print(f\"Training files uploaded: {train_file_names}\")\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 3) Upload new input file\n",
        "# =========================\n",
        "print(\"Upload 1 new input CSV file to analyze\")\n",
        "uploaded_input = files.upload()\n",
        "\n",
        "input_file_names = list(uploaded_input.keys())\n",
        "if len(input_file_names) != 1:\n",
        "    raise ValueError(\"Please upload exactly 1 input CSV for analysis.\")\n",
        "\n",
        "input_file_name = input_file_names[0]\n",
        "print(f\"Input file uploaded: {input_file_name}\")\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 4) Helpers\n",
        "# =========================\n",
        "def clean_columns(df: pd.DataFrame) -> pd.DataFrame:\n",
        "    df = df.copy()\n",
        "    df.columns = [\n",
        "        re.sub(r\"[^a-z0-9]+\", \"_\", str(c).strip().lower()).strip(\"_\")\n",
        "        for c in df.columns\n",
        "    ]\n",
        "    return df\n",
        "\n",
        "\n",
        "def find_column(df: pd.DataFrame, candidates):\n",
        "    cols = list(df.columns)\n",
        "    for cand in candidates:\n",
        "        for c in cols:\n",
        "            if cand == c:\n",
        "                return c\n",
        "    for cand in candidates:\n",
        "        for c in cols:\n",
        "            if cand in c:\n",
        "                return c\n",
        "    return None\n",
        "\n",
        "\n",
        "def coerce_numeric(series: pd.Series) -> pd.Series:\n",
        "    return pd.to_numeric(series, errors=\"coerce\")\n",
        "\n",
        "\n",
        "def parse_datetime_column(df: pd.DataFrame):\n",
        "    dt_candidates = [\n",
        "        \"timestamp\", \"datetime\", \"date_time\", \"time\", \"date\", \"datetime_utc\"\n",
        "    ]\n",
        "    dt_col = find_column(df, dt_candidates)\n",
        "    if dt_col:\n",
        "        parsed = pd.to_datetime(df[dt_col], errors=\"coerce\")\n",
        "        if parsed.notna().sum() > 0:\n",
        "            return dt_col, parsed\n",
        "    return None, None\n",
        "\n",
        "\n",
        "def standardize_weather_df(df: pd.DataFrame, source_name: str = \"unknown\") -> pd.DataFrame:\n",
        "    df = clean_columns(df)\n",
        "\n",
        "    temp_col = find_column(df, [\n",
        "        \"temperature\", \"temp_f\", \"temp\", \"air_temperature\", \"outdoor_temperature\"\n",
        "    ])\n",
        "    humidity_col = find_column(df, [\n",
        "        \"humidity\", \"relative_humidity\", \"rh\"\n",
        "    ])\n",
        "    rain_col = find_column(df, [\n",
        "        \"rain\", \"rainfall\", \"precip\", \"precipitation\", \"rain_mm\", \"precipitation_mm\"\n",
        "    ])\n",
        "    wind_col = find_column(df, [\n",
        "        \"wind_speed\", \"windspeed\", \"wind\"\n",
        "    ])\n",
        "    pressure_col = find_column(df, [\n",
        "        \"pressure\", \"barometric_pressure\"\n",
        "    ])\n",
        "    solar_col = find_column(df, [\n",
        "        \"solar_radiation\", \"solar\", \"radiation\"\n",
        "    ])\n",
        "\n",
        "    dt_col, parsed_dt = parse_datetime_column(df)\n",
        "\n",
        "    out = pd.DataFrame(index=df.index)\n",
        "    out[\"source_file\"] = source_name\n",
        "\n",
        "    if dt_col is not None:\n",
        "        out[\"timestamp\"] = parsed_dt\n",
        "        out[\"hour\"] = parsed_dt.dt.hour\n",
        "        out[\"dayofweek\"] = parsed_dt.dt.dayofweek\n",
        "        out[\"month\"] = parsed_dt.dt.month\n",
        "        out[\"is_weekend\"] = parsed_dt.dt.dayofweek.isin([5, 6]).astype(float)\n",
        "    else:\n",
        "        out[\"timestamp\"] = pd.NaT\n",
        "        out[\"hour\"] = np.nan\n",
        "        out[\"dayofweek\"] = np.nan\n",
        "        out[\"month\"] = np.nan\n",
        "        out[\"is_weekend\"] = np.nan\n",
        "\n",
        "    out[\"temperature\"] = coerce_numeric(df[temp_col]) if temp_col else np.nan\n",
        "    out[\"humidity\"] = coerce_numeric(df[humidity_col]) if humidity_col else np.nan\n",
        "    out[\"rain_amount\"] = coerce_numeric(df[rain_col]) if rain_col else 0.0\n",
        "    out[\"wind_speed\"] = coerce_numeric(df[wind_col]) if wind_col else np.nan\n",
        "    out[\"pressure\"] = coerce_numeric(df[pressure_col]) if pressure_col else np.nan\n",
        "    out[\"solar_radiation\"] = coerce_numeric(df[solar_col]) if solar_col else np.nan\n",
        "\n",
        "    out[\"rain_flag\"] = (out[\"rain_amount\"].fillna(0) > 0).astype(int)\n",
        "\n",
        "    out[\"temp_x_humidity\"] = out[\"temperature\"] * out[\"humidity\"]\n",
        "    out[\"temp_minus_humidity\"] = out[\"temperature\"] - out[\"humidity\"]\n",
        "\n",
        "    out[\"temp_roll3\"] = out[\"temperature\"].rolling(window=3, min_periods=1).mean()\n",
        "    out[\"humidity_roll3\"] = out[\"humidity\"].rolling(window=3, min_periods=1).mean()\n",
        "    out[\"rain_roll3\"] = out[\"rain_amount\"].rolling(window=3, min_periods=1).mean()\n",
        "\n",
        "    return out\n",
        "\n",
        "\n",
        "def load_csv_from_uploaded(upload_dict_key, upload_dict):\n",
        "    return pd.read_csv(io.BytesIO(upload_dict[upload_dict_key]))\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 5) Load and standardize training data\n",
        "# =========================\n",
        "train_frames = []\n",
        "for fname in train_file_names:\n",
        "    raw_df = load_csv_from_uploaded(fname, uploaded_train)\n",
        "    std_df = standardize_weather_df(raw_df, source_name=fname)\n",
        "    train_frames.append(std_df)\n",
        "\n",
        "train_df = pd.concat(train_frames, ignore_index=True)\n",
        "display(train_df.head())\n",
        "\n",
        "print(\"Training shape:\", train_df.shape)\n",
        "print(\"Rain rows:\", int(train_df[\"rain_flag\"].sum()))\n",
        "print(\"Rain frequency:\", round(train_df[\"rain_flag\"].mean() * 100, 4), \"%\")\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 6) Trend analysis on training data\n",
        "# =========================\n",
        "trend_lines = []\n",
        "trend_lines.append(f\"Training rows: {len(train_df)}\")\n",
        "trend_lines.append(f\"Training files: {len(train_file_names)}\")\n",
        "trend_lines.append(f\"Rain rows: {int(train_df['rain_flag'].sum())}\")\n",
        "trend_lines.append(f\"Rain frequency (%): {train_df['rain_flag'].mean() * 100:.4f}\")\n",
        "\n",
        "if train_df[\"temperature\"].notna().sum() > 0:\n",
        "    trend_lines.append(f\"Average temperature overall: {train_df['temperature'].mean():.2f}\")\n",
        "\n",
        "if train_df.loc[train_df[\"rain_flag\"] == 1, \"temperature\"].notna().sum() > 0:\n",
        "    trend_lines.append(\n",
        "        f\"Average temperature when raining: \"\n",
        "        f\"{train_df.loc[train_df['rain_flag'] == 1, 'temperature'].mean():.2f}\"\n",
        "    )\n",
        "\n",
        "if train_df[\"humidity\"].notna().sum() > 0:\n",
        "    trend_lines.append(f\"Average humidity overall: {train_df['humidity'].mean():.2f}\")\n",
        "\n",
        "if train_df.loc[train_df[\"rain_flag\"] == 1, \"humidity\"].notna().sum() > 0:\n",
        "    trend_lines.append(\n",
        "        f\"Average humidity when raining: \"\n",
        "        f\"{train_df.loc[train_df['rain_flag'] == 1, 'humidity'].mean():.2f}\"\n",
        "    )\n",
        "\n",
        "corr_temp_rain = train_df[[\"temperature\", \"rain_amount\"]].corr(numeric_only=True).iloc[0, 1]\n",
        "corr_humidity_rain = train_df[[\"humidity\", \"rain_amount\"]].corr(numeric_only=True).iloc[0, 1]\n",
        "\n",
        "trend_lines.append(f\"Correlation: temperature vs rain_amount = {corr_temp_rain:.4f}\")\n",
        "trend_lines.append(f\"Correlation: humidity vs rain_amount = {corr_humidity_rain:.4f}\")\n",
        "\n",
        "hourly_rain = train_df.groupby(\"hour\", dropna=True)[\"rain_flag\"].mean().reset_index()\n",
        "if len(hourly_rain) > 0:\n",
        "    best_hour = hourly_rain.sort_values(\"rain_flag\", ascending=False).iloc[0]\n",
        "    trend_lines.append(\n",
        "        f\"Highest rain likelihood by hour: {int(best_hour['hour'])}:00 \"\n",
        "        f\"({best_hour['rain_flag'] * 100:.2f}%)\"\n",
        "    )\n",
        "\n",
        "report_path = os.path.join(OUTPUT_DIR, \"training_trend_report.txt\")\n",
        "with open(report_path, \"w\") as f:\n",
        "    f.write(\"\\n\".join(trend_lines))\n",
        "\n",
        "print(\"\\n\".join(trend_lines))\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 7) Visualize training trends\n",
        "# =========================\n",
        "plt.figure(figsize=(8, 5))\n",
        "plot_df = train_df.dropna(subset=[\"temperature\", \"rain_amount\"])\n",
        "plt.scatter(plot_df[\"temperature\"], plot_df[\"rain_amount\"], alpha=0.5)\n",
        "plt.xlabel(\"Temperature\")\n",
        "plt.ylabel(\"Rain Amount\")\n",
        "plt.title(\"Temperature vs Rain Amount\")\n",
        "plt.tight_layout()\n",
        "temp_rain_plot = os.path.join(OUTPUT_DIR, \"temp_vs_rain.png\")\n",
        "plt.savefig(temp_rain_plot, dpi=200)\n",
        "plt.show()\n",
        "\n",
        "numeric_cols_for_corr = [\n",
        "    \"temperature\", \"humidity\", \"rain_amount\", \"wind_speed\",\n",
        "    \"pressure\", \"solar_radiation\", \"hour\", \"dayofweek\", \"month\",\n",
        "    \"temp_x_humidity\", \"temp_minus_humidity\", \"temp_roll3\",\n",
        "    \"humidity_roll3\", \"rain_roll3\"\n",
        "]\n",
        "corr_df = train_df[numeric_cols_for_corr].copy()\n",
        "corr_matrix = corr_df.corr(numeric_only=True)\n",
        "\n",
        "plt.figure(figsize=(10, 7))\n",
        "plt.imshow(corr_matrix, aspect=\"auto\")\n",
        "plt.xticks(range(len(corr_matrix.columns)), corr_matrix.columns, rotation=90)\n",
        "plt.yticks(range(len(corr_matrix.index)), corr_matrix.index)\n",
        "plt.colorbar()\n",
        "plt.title(\"Correlation Heatmap\")\n",
        "plt.tight_layout()\n",
        "corr_plot = os.path.join(OUTPUT_DIR, \"correlation_heatmap.png\")\n",
        "plt.savefig(corr_plot, dpi=200)\n",
        "plt.show()\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 8) Train models\n",
        "# =========================\n",
        "feature_cols = [\n",
        "    \"temperature\", \"humidity\", \"wind_speed\", \"pressure\", \"solar_radiation\",\n",
        "    \"hour\", \"dayofweek\", \"month\", \"is_weekend\",\n",
        "    \"temp_x_humidity\", \"temp_minus_humidity\",\n",
        "    \"temp_roll3\", \"humidity_roll3\", \"rain_roll3\",\n",
        "    \"source_file\"\n",
        "]\n",
        "\n",
        "X = train_df[feature_cols].copy()\n",
        "y_class = train_df[\"rain_flag\"].astype(int)\n",
        "y_reg = train_df[\"rain_amount\"].astype(float)\n",
        "\n",
        "numeric_features = [c for c in feature_cols if c != \"source_file\"]\n",
        "categorical_features = [\"source_file\"]\n",
        "\n",
        "numeric_transformer = Pipeline(steps=[\n",
        "    (\"imputer\", SimpleImputer(strategy=\"median\")),\n",
        "    (\"scaler\", StandardScaler())\n",
        "])\n",
        "\n",
        "categorical_transformer = Pipeline(steps=[\n",
        "    (\"imputer\", SimpleImputer(strategy=\"most_frequent\")),\n",
        "    (\"onehot\", OneHotEncoder(handle_unknown=\"ignore\"))\n",
        "])\n",
        "\n",
        "preprocessor = ColumnTransformer(\n",
        "    transformers=[\n",
        "        (\"num\", numeric_transformer, numeric_features),\n",
        "        (\"cat\", categorical_transformer, categorical_features),\n",
        "    ]\n",
        ")\n",
        "\n",
        "clf_pipeline = Pipeline(steps=[\n",
        "    (\"preprocessor\", preprocessor),\n",
        "    (\"model\", RandomForestClassifier(\n",
        "        n_estimators=200,\n",
        "        random_state=42,\n",
        "        class_weight=\"balanced\"\n",
        "    ))\n",
        "])\n",
        "\n",
        "reg_pipeline = Pipeline(steps=[\n",
        "    (\"preprocessor\", preprocessor),\n",
        "    (\"model\", RandomForestRegressor(\n",
        "        n_estimators=200,\n",
        "        random_state=42\n",
        "    ))\n",
        "])\n",
        "\n",
        "# Classification metrics only if both classes exist\n",
        "class_metrics = {}\n",
        "if y_class.nunique() > 1:\n",
        "    X_train_c, X_test_c, y_train_c, y_test_c = train_test_split(\n",
        "        X, y_class, test_size=0.2, random_state=42, stratify=y_class\n",
        "    )\n",
        "    clf_pipeline.fit(X_train_c, y_train_c)\n",
        "    y_pred_c = clf_pipeline.predict(X_test_c)\n",
        "\n",
        "    class_metrics[\"accuracy\"] = accuracy_score(y_test_c, y_pred_c)\n",
        "    class_metrics[\"precision\"] = precision_score(y_test_c, y_pred_c, zero_division=0)\n",
        "    class_metrics[\"recall\"] = recall_score(y_test_c, y_pred_c, zero_division=0)\n",
        "    class_metrics[\"f1\"] = f1_score(y_test_c, y_pred_c, zero_division=0)\n",
        "\n",
        "    try:\n",
        "        y_prob_c = clf_pipeline.predict_proba(X_test_c)[:, 1]\n",
        "        class_metrics[\"roc_auc\"] = roc_auc_score(y_test_c, y_prob_c)\n",
        "    except:\n",
        "        class_metrics[\"roc_auc\"] = np.nan\n",
        "\n",
        "    clf_pipeline.fit(X, y_class)\n",
        "else:\n",
        "    clf_pipeline.fit(X, y_class)\n",
        "    class_metrics[\"note\"] = \"Only one class present in training data; classifier metrics not meaningful.\"\n",
        "\n",
        "# Regression metrics only if some non-null rain values exist\n",
        "reg_metrics = {}\n",
        "if y_reg.notna().sum() > 10:\n",
        "    X_train_r, X_test_r, y_train_r, y_test_r = train_test_split(\n",
        "        X, y_reg, test_size=0.2, random_state=42\n",
        "    )\n",
        "    reg_pipeline.fit(X_train_r, y_train_r)\n",
        "    y_pred_r = reg_pipeline.predict(X_test_r)\n",
        "\n",
        "    reg_metrics[\"mae\"] = mean_absolute_error(y_test_r, y_pred_r)\n",
        "    reg_metrics[\"r2\"] = r2_score(y_test_r, y_pred_r)\n",
        "\n",
        "    reg_pipeline.fit(X, y_reg)\n",
        "else:\n",
        "    reg_pipeline.fit(X, y_reg)\n",
        "    reg_metrics[\"note\"] = \"Not enough data for reliable regression metrics.\"\n",
        "\n",
        "joblib.dump(clf_pipeline, os.path.join(OUTPUT_DIR, \"rain_classifier.joblib\"))\n",
        "joblib.dump(reg_pipeline, os.path.join(OUTPUT_DIR, \"rain_regressor.joblib\"))\n",
        "\n",
        "metrics_path = os.path.join(OUTPUT_DIR, \"model_metrics.json\")\n",
        "with open(metrics_path, \"w\") as f:\n",
        "    json.dump(\n",
        "        {\"classification\": class_metrics, \"regression\": reg_metrics},\n",
        "        f,\n",
        "        indent=2\n",
        "    )\n",
        "\n",
        "print(\"Classification metrics:\", class_metrics)\n",
        "print(\"Regression metrics:\", reg_metrics)\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 9) Analyze new input CSV\n",
        "# =========================\n",
        "input_raw = load_csv_from_uploaded(input_file_name, uploaded_input)\n",
        "input_std = standardize_weather_df(input_raw, source_name=input_file_name)\n",
        "\n",
        "X_new = input_std[feature_cols].copy()\n",
        "\n",
        "if hasattr(clf_pipeline.named_steps[\"model\"], \"predict_proba\"):\n",
        "    input_std[\"predicted_rain_probability\"] = clf_pipeline.predict_proba(X_new)[:, 1]\n",
        "else:\n",
        "    input_std[\"predicted_rain_probability\"] = clf_pipeline.predict(X_new)\n",
        "\n",
        "input_std[\"predicted_rain_flag\"] = clf_pipeline.predict(X_new)\n",
        "input_std[\"predicted_rain_amount\"] = reg_pipeline.predict(X_new)\n",
        "\n",
        "predictions_path = os.path.join(OUTPUT_DIR, \"input_predictions.csv\")\n",
        "input_std.to_csv(predictions_path, index=False)\n",
        "\n",
        "display(input_std.head())\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 10) Input analysis report\n",
        "# =========================\n",
        "input_lines = []\n",
        "input_lines.append(f\"Input file: {input_file_name}\")\n",
        "input_lines.append(f\"Rows analyzed: {len(input_std)}\")\n",
        "\n",
        "if input_std[\"temperature\"].notna().sum() > 0:\n",
        "    input_lines.append(f\"Average input temperature: {input_std['temperature'].mean():.2f}\")\n",
        "\n",
        "if input_std[\"humidity\"].notna().sum() > 0:\n",
        "    input_lines.append(f\"Average input humidity: {input_std['humidity'].mean():.2f}\")\n",
        "\n",
        "input_lines.append(\n",
        "    f\"Average predicted rain probability: \"\n",
        "    f\"{input_std['predicted_rain_probability'].mean():.4f}\"\n",
        ")\n",
        "input_lines.append(\n",
        "    f\"Predicted rain-positive rows: \"\n",
        "    f\"{int(input_std['predicted_rain_flag'].sum())}\"\n",
        ")\n",
        "input_lines.append(\n",
        "    f\"Average predicted rain amount: \"\n",
        "    f\"{input_std['predicted_rain_amount'].mean():.4f}\"\n",
        ")\n",
        "\n",
        "# Compare input temps to historical raining temps if available\n",
        "hist_rain_temp = train_df.loc[train_df[\"rain_flag\"] == 1, \"temperature\"].dropna()\n",
        "if len(hist_rain_temp) > 0 and input_std[\"temperature\"].notna().sum() > 0:\n",
        "    input_lines.append(\n",
        "        f\"Historical raining temp mean: {hist_rain_temp.mean():.2f}\"\n",
        "    )\n",
        "    input_lines.append(\n",
        "        f\"Difference between input mean temp and historical raining temp mean: \"\n",
        "        f\"{input_std['temperature'].mean() - hist_rain_temp.mean():.2f}\"\n",
        "    )\n",
        "\n",
        "input_report_path = os.path.join(OUTPUT_DIR, \"input_analysis_report.txt\")\n",
        "with open(input_report_path, \"w\") as f:\n",
        "    f.write(\"\\n\".join(input_lines))\n",
        "\n",
        "print(\"\\n\".join(input_lines))\n",
        "\n",
        "\n",
        "# =========================\n",
        "# 11) Plot predictions for input\n",
